{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "SP_VISION_BUILD_AUTO_BUFF": "OFF",
        "SP_VISION_BUILD_OMNIPERCEPTION": "OFF"
      }
    },
    {
      "name": "dev-debug",
      "inherits": "base",
      "displayName": "Dev Debug",
      "description": "Default clangd/cmake development preset for the Linux x86_64 NUC environment.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "dev-release",
      "inherits": "base",
      "displayName": "Dev Release",
      "description": "Release build preset matching the deployment target.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-debug",
      "configurePreset": "dev-debug"
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-release"
    }
  ]
}
